# Clé API Resend (https://resend.com) pour l'envoi des emails du formulaire de contact
RESEND_API_KEY=

# Adresse email qui doit recevoir les demandes de devis
CONTACT_EMAIL=digitalkronosagency@gmail.com

# Adresse email d'expédition vérifiée sur Resend (domaine vérifié requis en production)
CONTACT_FROM_EMAIL=onboarding@resend.dev
