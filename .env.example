# Clé API Resend (https://resend.com) pour l'envoi des emails du formulaire de contact
RESEND_API_KEY=

# Adresse email qui doit recevoir les demandes de devis
CONTACT_EMAIL=digitalkronosagency@gmail.com

# Adresse email d'expédition vérifiée sur Resend (domaine vérifié requis en production)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Mot de passe de l'espace admin (/admin) permettant d'ajouter/supprimer les
# photos de la section Réalisations. À choisir soi-même, suffisamment long.
ADMIN_PASSWORD=

# Secret utilisé pour signer le cookie de session admin. Générer une chaîne
# aléatoire longue, par exemple avec : openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Fourni automatiquement par Vercel une fois le Blob Store créé et connecté
# au projet (Storage -> Create Database -> Blob). Ne pas renseigner à la main
# en production ; nécessaire en local uniquement pour tester l'upload de photos.
BLOB_READ_WRITE_TOKEN=
